VITE_APP_WEB_ENV=prod


# ========== 运行时配置（原 public/env/test/env.js） ==========
VITE_APP_BASE_URL=/jeeStudio/gtoa/a/
VITE_APP_SERVER_URL=/jeeStudio/gtoa/a/
VITE_APP_FILE_HOST=
